# Server
ENV=development
HOST=0.0.0.0
PORT=8000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=interviewlab

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Email (invitations)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=InterviewLab <no-reply@interviewlab.ai>

# AI analysis
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# File storage (starter projects, images, recordings)
S3_ENDPOINT=
S3_BUCKET=interviewlab-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
RECORDINGS_DIR=./data/recordings
RECORDING_RETENTION_DAYS=30
RECORDING_MAX_BYTES=2000000000
RECORDING_MAX_CHUNK_BYTES=25000000

# Misc
INVITE_LINK_BASE_URL=http://localhost:5173/test
